{
  "name": "viralops-agents",
  "version": "1.0.0",
  "description": "AI Marketing Agent Team — 5 autonomous agents for viral content pipeline",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "echo build skipped — use tsx",
    "start": "tsx src/index.ts",
    "run:pipeline": "tsx src/index.ts run",
    "run:research": "tsx src/index.ts run --agent research",
    "run:clip": "tsx src/index.ts run --agent clip",
    "run:edit": "tsx src/index.ts run --agent edit",
    "run:post": "tsx src/index.ts run --agent post",
    "run:finance": "tsx src/index.ts run --agent finance",
    "status": "tsx src/index.ts status",
    "logs": "tsx src/index.ts logs",
    "setup": "tsx src/index.ts setup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "viral",
    "marketing",
    "automation"
  ],
  "author": "DealerMattAI",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@supabase/supabase-js": "^2.46.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "googleapis": "^173.0.0",
    "node-cron": "^3.0.3",
    "ora": "^8.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^16.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
